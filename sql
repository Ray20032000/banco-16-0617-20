CREATE TABLE usuario (
    id_usuario INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    telefone VARCHAR(20),
    senha VARCHAR(255) NOT NULL,
    id_cargo INT NOT NULL,
    conta_confirmada SMALLINT DEFAULT 0,
    bloqueado SMALLINT DEFAULT 0,
    tentativas_login INT DEFAULT 0,
    FOREIGN KEY (id_cargo) REFERENCES cargo(id_cargo)
);

CREATE TABLE status (
    id_status INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    nome VARCHAR(50) NOT NULL
);

CREATE TABLE chamado (
    id_chamado INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    sala VARCHAR(50) NOT NULL,
    patrimonio VARCHAR(50) NOT NULL,
    descricao BLOB SUB_TYPE TEXT NOT NULL,
    imagem_problema VARCHAR(255), 
    data_abertura TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    data_finalizacao TIMESTAMP,
    id_status INT NOT NULL,
    id_professor INT NOT NULL, 
    id_responsavel INT,        
    FOREIGN KEY (id_status) REFERENCES status(id_status),
    FOREIGN KEY (id_professor) REFERENCES usuario(id_usuario),
    FOREIGN KEY (id_responsavel) REFERENCES usuario(id_usuario)
);

CREATE TABLE comentario (
    id_comentario INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    texto BLOB SUB_TYPE TEXT NOT NULL,
    data_comentario TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    id_chamado INT NOT NULL,
    id_usuario INT NOT NULL, 
    FOREIGN KEY (id_chamado) REFERENCES chamado(id_chamado),
    FOREIGN KEY (id_usuario) REFERENCES usuario(id_usuario)
);

CREATE TABLE confirmar_codigo (
    id_confirmacao INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    id_usuario INT NOT NULL,
    codigo VARCHAR(10) NOT NULL,
    utilizado SMALLINT DEFAULT 0,
    data_criacao TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (id_usuario) REFERENCES usuario(id_usuario)
);

CREATE TABLE recuperar_senha (
    id_recuperacao INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    id_usuario INT NOT NULL,
    codigo VARCHAR(10) NOT NULL,
    expiracao TIMESTAMP NOT NULL,
    utilizado SMALLINT DEFAULT 0,
    FOREIGN KEY (id_usuario) REFERENCES usuario(id_usuario)
);

CREATE TABLE historico_senhas (
    id_historico INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    id_usuario INT NOT NULL,
    senha_antiga VARCHAR(255) NOT NULL,
    data_troca TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (id_usuario) REFERENCES usuario(id_usuario)
);

CREATE TABLE CARGO (
    ID_CARGO INTEGER NOT NULL PRIMARY KEY,
    NOME VARCHAR(50) NOT NULL
);


